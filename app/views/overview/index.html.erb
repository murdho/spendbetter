<div class="min-w-full">
  <h1 class="font-bold text-4xl">Overview</h1>
  <div class="w-full">
    <% @bank_transactions_for_overview.each do |month, transactions_by_category_type| %>
      <div class="flex gap-10">
        <div class="w-1/2">
          <%= render partial: "summary", locals: { month: month, transactions_by_category_type: transactions_by_category_type } %>
        </div>

        <div class="w-1/2">
          <%= render partial: "details", locals: { bank_transactions: @bank_transactions_for_details[month] } %>
        </div>
      </div>
    <% end %>
  </div>
</div>
