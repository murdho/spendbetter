<h2 class="font-bold text-2xl mt-16 mb-4">
  <% if selected_category_id.present? %>
    <%= bank_transactions.first.category_name %>
    <span class="cursor-pointer float-end">
      <%= link_to_select_category "⨯", nil %>
    </span>
  <% else %>
    Uncategorized
  <% end %>
</h2>

<div class="ring-1 ring-gray-300 rounded-lg overflow-scroll">
  <table class="min-w-full divide-y divide-gray-300">
    <thead>
    <tr>
      <th scope="col" class="whitespace-nowrap py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900">Date</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900">Amount</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900">Currency</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900">Party</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900">Description</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900">Category</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900">Rule</th>
      <th scope="col" class="whitespace-nowrap px-2 py-3.5 text-left text-sm font-semibold text-gray-900"></th>
    </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
    <% bank_transactions.each do |transaction| %>
      <tr>
        <td class="whitespace-nowrap py-2 pl-4 pr-3 text-sm text-gray-500 text-left"><%= transaction.date || "—" %></td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-right"><%= money_tag transaction.amount %></td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-left"><%= transaction.currency %></td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-left" title="<%= transaction.party %>"><%= transaction.party&.truncate(25) %></td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-left" title="<%= transaction.description %>"><%= transaction.description&.truncate(25) %></td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-left">
          <%= select_tag "category", options_from_collection_for_select(@categories_for_select, :id, :name, transaction.category_id), class: "border-none outline-none px-0 py-0 text-sm cursor-pointer" %>
        </td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-left"><%= transaction.rule_id %></td>
        <td class="whitespace-nowrap px-2 py-2 text-sm text-gray-500 text-left"><%= link_to "Save", "#" %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
